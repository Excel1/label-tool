# MQTT connection
VITE_MQTT_BROKER_URL=mqtt://localhost:1883
VITE_MQTT_USERNAME=
VITE_MQTT_PASSWORD=
VITE_MQTT_CLIENT_ID_PREFIX=label-tool
VITE_MQTT_INPUT_TOPIC=label-tool/incoming
VITE_MQTT_OUTPUT_TOPIC=label-tool/annotated

# Mock behavior for store.enqueueMockFrame()
VITE_MOCK_INCLUDE_LABELS=true

# Allowed label classes (comma-separated, index = YOLO classId)
VITE_YOLO_LABEL_CLASSES=person,car,truck
